{
  "name": "better-atimonan",
  "version": "1.0.0",
  "private": true,
  "description": "Better Atimonan",
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@better-atimonan/frontend",
    "dev:backend": "turbo run dev --filter=@better-atimonan/backend",
    "dev:worker": "turbo run dev --filter=@better-atimonan/worker",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "clean": "turbo run clean",
    "db:migrate": "turbo run db:migrate --filter=@better-atimonan/backend",
    "db:seed": "turbo run db:seed --filter=@better-atimonan/backend",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}